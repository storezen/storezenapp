# API base must end with /api (Express mounts routes there).
# Production: your deployed API URL.
# Local with Next on 3001 + API on 3000: use same-origin so dev rewrites proxy to the API:
#   NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Or call the API directly (ensure CORS allows the web origin):
#   NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_API_URL=https://vendrix.up.railway.app/api
# Optional: where to proxy /api in dev (next.config rewrites). Default is http://127.0.0.1:3000
# API_PROXY_URL=http://127.0.0.1:3000
# Admin: show small on-screen API base hint (staging / local smoke tests only)
# NEXT_PUBLIC_DEBUG_ADMIN=1
NEXT_PUBLIC_STORE_NAME=StorePK
# Slug of the store row (public GET /stores/:slug). Used for catalog, checkout storeId, and StorePixels.
NEXT_PUBLIC_STORE_SLUG=demo
NEXT_PUBLIC_WHATSAPP=923001234567
# Optional store contact phone (shown in footer)
# NEXT_PUBLIC_PHONE=03001234567
# Optional: when set, layout loads these and skips DB-backed pixel from Settings for that network.
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# NEXT_PUBLIC_SITE_URL=https://vendrix.pk
