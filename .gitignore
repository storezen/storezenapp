# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# --- Dependencies ---
node_modules/

# --- Build / cache (monorepo) ---
dist/
out/
build/
.next/
.turbo/
.vercel/
.nuxt/
.svelte-kit/
*.tsbuildinfo

# Vite
.vite/

# --- Test / coverage ---
coverage/
.nyc_output/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
testem.log

# --- Environment (secrets) — templates stay in repo ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!**/.env.example

# --- OS / editor ---
.DS_Store
Thumbs.db
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# VSCode (keep shared team settings if present)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- Misc ---
/.sass-cache
/connect.lock
/libpeerconnection.log
/typings
tmp/
*.pem

# Replit / local tooling
.replit
.replitignore
.cache/
.local/
.replit-artifact/

# pnpm store (local mirror)
.pnpm-store/

# Cursor / agent scratch (not source)
.agents/
attached_assets/

# Cursor rules you explicitly exclude from repo
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Archives / dumps
*.tar.gz
