# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# --- Dependencies ---
node_modules/

# --- Build / cache (monorepo) ---
dist/
out/
build/
.next/
.turbo/
.vercel/
.nuxt/
.svelte-kit/
*.tsbuildinfo

# Vite
.vite/

# --- Test / coverage ---
coverage/
.nyc_output/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
testem.log

# --- Environment (secrets) — templates stay in repo ---
.env
.env.*
!.env.example
!**/.env.example
.envrc
.direnv/
*.pem
*.p12
*.pfx
id_rsa
id_rsa.pub
*.secret

# --- OS / editor ---
.DS_Store
Thumbs.db
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# VSCode (keep shared team settings if present)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- Misc ---
/.sass-cache
/connect.lock
/libpeerconnection.log
/typings
tmp/

# Local-only editor / environment files (optional)
.replit
.replitignore
.cache/
.local/
.replit-artifact/

# pnpm store (local mirror)
.pnpm-store/

# IDE scratch and local asset dumps (not source)
.agents/
attached_assets/

# Cursor rules you explicitly exclude from repo
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Archives / dumps
*.tar.gz

# Playwright / e2e artifacts (if added later)
playwright-report/
test-results/
blob-report/

# OS metadata (Windows)
Desktop.ini
