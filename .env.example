# Monorepo environment template — copy to `.env` at repo root and/or per-app `.env` files.
# Never commit real secrets. See SECURITY.md / DEPLOYMENT.md.

# ─── Shared / API ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=minimum-32-chars-use-long-random-string-in-production
ADMIN_EMAIL=admin@storepk.com
ADMIN_PASSWORD=strongpassword
PORT=3000
NODE_ENV=production
FRONTEND_ORIGINS=https://storepk.vercel.app

# ULTRAMSG_INSTANCE_ID=
# ULTRAMSG_TOKEN=
# POSTEX_API_KEY=
# GEMINI_API_KEY=

# ─── Storefront (apps/pk-store, Vite) ─────────────────────────────────────────
# API base must include `/api` (Express mounts the router at /api).
VITE_API_URL=http://localhost:3000/api
VITE_DEFAULT_STORE=demo
VITE_APP_NAME=StorePK
# VITE_REF_BASE_URL=

# ─── Next.js apps (dashboard + platform admin) ───────────────────────────────
# Next.js web app uses port 3001 (see apps/web/package.json). API often uses PORT=3000.
# Option A — same origin (recommended for local): browser → Next:3001/api → rewrite → API:3000/api
#   NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Option B — browser calls API directly:
#   NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_ADMIN_EMAIL=admin@storepk.com
