# Storefront — copy to apps/web/.env for local dev (do not commit).

VITE_API_URL=http://localhost:8080/api
VITE_DEFAULT_STORE_SLUG=zorvik

# Optional: apex domain for tenant subdomains (same value as API STORE_PUBLIC_ROOT_DOMAIN).
# Example: zorvik.pk → store at https://demo.zorvik.pk uses slug "demo".
# VITE_STORE_PUBLIC_ROOT_DOMAIN=zorvik.pk
