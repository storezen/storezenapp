# Storezen - Vercel Environment Variables
# IMPORTANT: After Railway deploys, replace [RAILWAY-APP-NAME] with your actual Railway app name

# API URL - Must end with /api
NEXT_PUBLIC_API_URL=https://[RAILWAY-APP-NAME].up.railway.app/api

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=https://[RAILWAY-APP-NAME].up.railway.app

# Store Configuration
NEXT_PUBLIC_STORE_NAME=Storezen
NEXT_PUBLIC_STORE_SLUG=demo
NEXT_PUBLIC_WHATSAPP=923001234567

# Admin
NEXT_PUBLIC_ADMIN_EMAIL=admin@storepk.com