# Storefront (Vite) — copy to apps/pk-store/.env (do not commit secrets).

# Must include `/api` — the API app mounts routes at http://host:port/api
VITE_API_URL=http://localhost:3000/api
VITE_DEFAULT_STORE=demo
VITE_APP_NAME=StorePK

# Optional referral base URL for influencer links.
# VITE_REF_BASE_URL=
