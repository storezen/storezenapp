{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["apps/admin/**", "apps/dashboard/**", ".env*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
